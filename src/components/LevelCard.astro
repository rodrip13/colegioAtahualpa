---
interface Props {
  title: string;
  description: string;
  image: string;
  href: string;
}

const { title, description, image, href } = Astro.props;
---

<a href={href} class="card card-hover group">
  <div class="relative h-64 overflow-hidden">
    <img 
      src={image} 
      alt={title}
      class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
    <h3 class="absolute bottom-4 left-4 text-2xl font-bold text-white">
      {title}
    </h3>
  </div>
  <div class="p-6">
    <p class="text-text-light mb-4">{description}</p>
    <span class="inline-flex items-center text-primary font-semibold group-hover:text-secondary transition-colors">
      Ver más
      <svg class="w-5 h-5 ml-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
      </svg>
    </span>
  </div>
</a>
