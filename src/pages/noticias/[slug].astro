---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const noticias = await getCollection("noticias");
  return noticias.map((noticia) => ({
    params: { slug: noticia.id },
    props: { noticia },
  }));
}

const { noticia } = Astro.props;
const { Content } = await render(noticia);
---

<BaseLayout title={noticia.data.title} description={noticia.data.description}>
  <Header />

  <main>
    <!-- Hero Image -->
    {noticia.data.heroImage && (
      <section class="relative h-[400px] md:h-[500px]">
        <img 
          src={noticia.data.heroImage}
          alt={noticia.data.title}
          class="w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent flex items-end">
          <div class="container-custom pb-12">
            {noticia.data.category && (
              <span class="inline-block px-4 py-2 bg-secondary text-white text-sm font-semibold rounded-full mb-4">
                {noticia.data.category}
              </span>
            )}
            <h1 class="text-3xl md:text-5xl font-bold text-white">
              {noticia.data.title}
            </h1>
          </div>
        </div>
      </section>
    )}

    <!-- Article Content -->
    <article class="section-padding">
      <div class="container-custom">
        <div class="max-w-3xl mx-auto">
          <!-- Meta info -->
          <div class="flex items-center text-text-light mb-8 pb-8 border-b">
            <time class="flex items-center">
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              {noticia.data.pubDate.toLocaleDateString('es-UY', {
                year: 'numeric',
                month: 'long',
                day: 'numeric'
              })}
            </time>
            {noticia.data.tags && (
              <div class="flex items-center ml-6">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
                </svg>
                {noticia.data.tags.map((tag) => (
                  <span class="inline-block px-2 py-1 bg-surface text-text-light text-xs rounded-full mr-2">
                    {tag}
                  </span>
                ))}
              </div>
            )}
          </div>

          <!-- Content -->
          <div class="prose prose-lg max-w-none text-text">
            <Content />
          </div>

          <!-- Back to News -->
          <div class="mt-12 pt-8 border-t">
            <a 
              href="/noticias"
              class="inline-flex items-center text-primary font-semibold hover:text-secondary transition-colors"
            >
              <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
              </svg>
              Volver a Noticias
            </a>
          </div>
        </div>
      </div>
    </article>
  </main>

  <Footer />
</BaseLayout>

<style is:global>
  .prose {
    color: var(--color-text);
  }
  
  .prose h2 {
    font-size: 1.875rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  
  .prose h3 {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }
  
  .prose p {
    margin-bottom: 1rem;
    line-height: 1.75;
  }
  
  .prose ul, .prose ol {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }
  
  .prose li {
    margin-bottom: 0.5rem;
  }
  
  .prose ul {
    list-style-type: disc;
  }
  
  .prose ol {
    list-style-type: decimal;
  }
  
  .prose a {
    color: var(--color-secondary);
    text-decoration: underline;
  }
  
  .prose a:hover {
    color: var(--color-primary);
  }
  
  .prose blockquote {
    border-left: 4px solid var(--color-secondary);
    padding-left: 1rem;
    font-style: italic;
    color: var(--color-text-light);
    margin: 1.5rem 0;
  }
  
  .prose img {
    border-radius: 0.5rem;
    margin: 1.5rem 0;
  }
  
  .prose strong {
    font-weight: 600;
    color: var(--color-primary);
  }
  
  .prose em {
    font-style: italic;
  }
</style>
