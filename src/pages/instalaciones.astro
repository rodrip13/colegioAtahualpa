---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const instalacionesInicial = [
  "https://colegioatahualpa.edu.uy/wp-content/uploads/2025/11/IMG_9381-scaled.jpg",
  "https://colegioatahualpa.edu.uy/wp-content/uploads/2025/11/IMG_9361-scaled.jpg",
  "https://colegioatahualpa.edu.uy/wp-content/uploads/2025/11/IMG_9336-scaled.jpg",
  "https://colegioatahualpa.edu.uy/wp-content/uploads/2025/11/IMG_9350-scaled.jpg",
  "https://colegioatahualpa.edu.uy/wp-content/uploads/2025/11/IMG_9295-scaled.jpg",
  "https://colegioatahualpa.edu.uy/wp-content/uploads/2025/11/IMG_9306-scaled.jpg",
  "https://colegioatahualpa.edu.uy/wp-content/uploads/2025/11/IMG_9310-scaled.jpg",
];

const instalacionesSecundaria = [
  "https://colegioatahualpa.edu.uy/wp-content/uploads/2025/11/IMG_9190-scaled.jpg",
  "https://colegioatahualpa.edu.uy/wp-content/uploads/2025/11/IMG_9282-scaled.jpg",
  "https://colegioatahualpa.edu.uy/wp-content/uploads/2025/11/IMG_9234-scaled.jpg",
  "https://colegioatahualpa.edu.uy/wp-content/uploads/2025/11/IMG_9220-scaled.jpg",
  "https://colegioatahualpa.edu.uy/wp-content/uploads/2025/11/IMG_9272-scaled.jpg",
  "https://colegioatahualpa.edu.uy/wp-content/uploads/2025/11/IMG_9213-scaled.jpg",
  "https://colegioatahualpa.edu.uy/wp-content/uploads/2025/11/IMG_9247-scaled.jpg",
];
---

<BaseLayout title="Instalaciones" description="Instalaciones del Colegio Atahualpa - Espacios diseñados para el aprendizaje">
  <Header />

  <main>
    <!-- Hero Banner -->
    <section class="relative h-[300px] md:h-[400px]">
      <img 
        src="https://colegioatahualpa.edu.uy/wp-content/uploads/2025/10/260880-P4WQ3T-13-01-1024x452.jpg"
        alt="Instalaciones"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-primary/80 to-primary/40 flex items-center">
        <div class="container-custom">
          <h1 class="text-4xl md:text-5xl font-bold text-white">Instalaciones</h1>
        </div>
      </div>
    </section>

    <!-- Introducción -->
    <section class="section-padding">
      <div class="container-custom">
        <div class="text-center max-w-3xl mx-auto">
          <p class="text-xl text-text-light">
            Contamos con modernas instalaciones diseñadas para el aprendizaje y desarrollo integral de nuestros alumnos. Espacios amplios, seguros y equipados con tecnología educativa.
          </p>
        </div>
      </div>
    </section>

    <!-- Inicial y Primaria -->
    <section class="section-padding bg-surface">
      <div class="container-custom">
        <div class="text-center mb-12">
          <h2 class="section-title">Inicial y Primaria</h2>
          <p class="section-subtitle mx-auto">
            Nuestro local insignia en Carmelo 1415
          </p>
        </div>

        <!-- Slider -->
        <div class="relative max-w-4xl mx-auto">
          <div id="slider-inicial" class="overflow-hidden rounded-lg shadow-xl">
            <div class="relative h-[400px] md:h-[500px]">
              {instalacionesInicial.map((image, index) => (
                <div 
                  class:list={["absolute inset-0 transition-opacity duration-500", { "opacity-100": index === 0, "opacity-0": index !== 0 }]}
                  data-slide-inicial={index}
                >
                  <img 
                    src={image}
                    alt={`Instalación Inicial ${index + 1}`}
                    class="w-full h-full object-cover"
                    loading={index === 0 ? "eager" : "lazy"}
                  />
                </div>
              ))}
            </div>

            <!-- Navigation -->
            <button id="prev-inicial" class="absolute left-4 top-1/2 -translate-y-1/2 z-10 p-3 bg-white/80 hover:bg-white rounded-full shadow-lg transition-colors">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
              </svg>
            </button>
            <button id="next-inicial" class="absolute right-4 top-1/2 -translate-y-1/2 z-10 p-3 bg-white/80 hover:bg-white rounded-full shadow-lg transition-colors">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </button>
          </div>

          <!-- Thumbnails -->
          <div class="flex justify-center mt-4 space-x-2 overflow-x-auto">
            {instalacionesInicial.map((image, index) => (
              <button 
                class:list={["w-20 h-16 flex-shrink-0 rounded-lg overflow-hidden border-2 transition-all", { "border-secondary": index === 0, "border-transparent opacity-60 hover:opacity-100": index !== 0 }]}
                data-thumb-inicial={index}
              >
                <img 
                  src={image}
                  alt={`Thumb ${index + 1}`}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </button>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Secundaria y Bachillerato -->
    <section class="section-padding">
      <div class="container-custom">
        <div class="text-center mb-12">
          <h2 class="section-title">Secundaria y Bachillerato</h2>
          <p class="section-subtitle mx-auto">
            Nuestro local en Millán 2920
          </p>
        </div>

        <!-- Slider -->
        <div class="relative max-w-4xl mx-auto">
          <div id="slider-secundaria" class="overflow-hidden rounded-lg shadow-xl">
            <div class="relative h-[400px] md:h-[500px]">
              {instalacionesSecundaria.map((image, index) => (
                <div 
                  class:list={["absolute inset-0 transition-opacity duration-500", { "opacity-100": index === 0, "opacity-0": index !== 0 }]}
                  data-slide-secundaria={index}
                >
                  <img 
                    src={image}
                    alt={`Instalación Secundaria ${index + 1}`}
                    class="w-full h-full object-cover"
                    loading={index === 0 ? "eager" : "lazy"}
                  />
                </div>
              ))}
            </div>

            <!-- Navigation -->
            <button id="prev-secundaria" class="absolute left-4 top-1/2 -translate-y-1/2 z-10 p-3 bg-white/80 hover:bg-white rounded-full shadow-lg transition-colors">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
              </svg>
            </button>
            <button id="next-secundaria" class="absolute right-4 top-1/2 -translate-y-1/2 z-10 p-3 bg-white/80 hover:bg-white rounded-full shadow-lg transition-colors">
              <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </button>
          </div>

          <!-- Thumbnails -->
          <div class="flex justify-center mt-4 space-x-2 overflow-x-auto">
            {instalacionesSecundaria.map((image, index) => (
              <button 
                class:list={["w-20 h-16 flex-shrink-0 rounded-lg overflow-hidden border-2 transition-all", { "border-secondary": index === 0, "border-transparent opacity-60 hover:opacity-100": index !== 0 }]}
                data-thumb-secundaria={index}
              >
                <img 
                  src={image}
                  alt={`Thumb ${index + 1}`}
                  class="w-full h-full object-cover"
                  loading="lazy"
                />
              </button>
            ))}
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  // Slider functionality for both galleries
  function setupSlider(sliderId: string, prevId: string, nextId: string, thumbPrefix: string, totalSlides: number) {
    let currentSlide = 0;

    function goToSlide(index: number) {
      const slides = document.querySelectorAll(`[data-${sliderId}="${index}"]`);
      const thumbs = document.querySelectorAll(`[data-${thumbPrefix}="${index}"]`);
      const allSlides = document.querySelectorAll(`[data-${sliderId}]`);
      const allThumbs = document.querySelectorAll(`[data-${thumbPrefix}]`);

      allSlides.forEach((slide, i) => {
        slide.classList.toggle('opacity-100', i === index);
        slide.classList.toggle('opacity-0', i !== index);
      });

      allThumbs.forEach((thumb, i) => {
        thumb.classList.toggle('border-secondary', i === index);
        thumb.classList.toggle('border-transparent', i !== index);
        thumb.classList.toggle('opacity-100', i === index);
        thumb.classList.toggle('opacity-60', i !== index);
      });

      currentSlide = index;
    }

    document.getElementById(prevId)?.addEventListener('click', () => {
      goToSlide((currentSlide - 1 + totalSlides) % totalSlides);
    });

    document.getElementById(nextId)?.addEventListener('click', () => {
      goToSlide((currentSlide + 1) % totalSlides);
    });

    document.querySelectorAll(`[data-${thumbPrefix}]`).forEach((thumb, index) => {
      thumb.addEventListener('click', () => goToSlide(index));
    });

    // Auto-advance
    setInterval(() => {
      goToSlide((currentSlide + 1) % totalSlides);
    }, 5000);
  }

  // Initialize both sliders
  setupSlider('slide-inicial', 'prev-inicial', 'next-inicial', 'thumb-inicial', 7);
  setupSlider('slide-secundaria', 'prev-secundaria', 'next-secundaria', 'thumb-secundaria', 7);
</script>
