---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Contacto" description="Contacto del Colegio Atahualpa - Comunícate con nosotros">
  <Header />

  <main>
    <!-- Hero Banner -->
    <section class="relative h-[300px] md:h-[400px]">
      <img 
        src="https://colegioatahualpa.edu.uy/wp-content/uploads/2025/10/260880-P4WQ3T-13-01-1024x452.jpg"
        alt="Contacto"
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-primary/80 to-primary/40 flex items-center">
        <div class="container-custom">
          <h1 class="text-4xl md:text-5xl font-bold text-white">Contacto</h1>
        </div>
      </div>
    </section>

    <!-- Info de Contacto -->
    <section class="section-padding">
      <div class="container-custom">
        <div class="text-center mb-12">
          <h2 class="section-title">Comunícate con Nosotros</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto mb-16">
          <!-- Inicial y Primaria -->
          <div class="text-center p-6 bg-surface rounded-lg">
            <img 
              src="https://colegioatahualpa.edu.uy/wp-content/uploads/2025/10/257-04-1024x876.png"
              alt="Inicial y Primaria"
              class="w-24 h-28 object-contain mx-auto mb-4"
            />
            <h3 class="text-xl font-bold text-primary mb-2">Inicial y Primaria</h3>
            <p class="text-text-light mb-2">Carmelo 1415</p>
            <p class="text-2xl font-bold text-secondary">Tel. 2336 44 54</p>
          </div>

          <!-- Secundaria y Bachillerato -->
          <div class="text-center p-6 bg-surface rounded-lg">
            <img 
              src="https://colegioatahualpa.edu.uy/wp-content/uploads/2025/10/257-02-1024x876.png"
              alt="Secundaria y Bachillerato"
              class="w-24 h-28 object-contain mx-auto mb-4"
            />
            <h3 class="text-xl font-bold text-primary mb-2">Secundaria y Bachillerato</h3>
            <p class="text-text-light mb-2">Millán 2920</p>
            <p class="text-2xl font-bold text-secondary">Tel. 22005418</p>
          </div>

          <!-- Administración -->
          <div class="text-center p-6 bg-surface rounded-lg">
            <img 
              src="https://colegioatahualpa.edu.uy/wp-content/uploads/2025/10/257-01-1024x869.png"
              alt="Administración"
              class="w-24 h-28 object-contain mx-auto mb-4"
            />
            <h3 class="text-xl font-bold text-primary mb-2">Administración</h3>
            <p class="text-text-light mb-2">&nbsp;</p>
            <p class="text-2xl font-bold text-secondary">Tel. 094 559 773</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Formulario de Contacto -->
    <section class="section-padding bg-surface">
      <div class="container-custom">
        <div class="max-w-2xl mx-auto">
          <div class="text-center mb-8">
            <h2 class="section-title">Envianos un mensaje</h2>
          </div>

          <form id="contact-form" class="bg-white rounded-lg shadow-xl p-8">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
              <div>
                <label for="nombre" class="block text-sm font-semibold text-primary mb-2">
                  Nombre *
                </label>
                <input 
                  type="text" 
                  id="nombre" 
                  name="nombre"
                  required
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-secondary focus:border-transparent transition-all"
                  placeholder="Tu nombre completo"
                />
              </div>

              <div>
                <label for="telefono" class="block text-sm font-semibold text-primary mb-2">
                  Teléfono *
                </label>
                <input 
                  type="tel" 
                  id="telefono" 
                  name="telefono"
                  required
                  class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-secondary focus:border-transparent transition-all"
                  placeholder="Tu número de teléfono"
                />
              </div>
            </div>

            <div class="mb-6">
              <label for="email" class="block text-sm font-semibold text-primary mb-2">
                Email *
              </label>
              <input 
                type="email" 
                id="email" 
                name="email"
                required
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-secondary focus:border-transparent transition-all"
                placeholder="tu@email.com"
              />
            </div>

            <div class="mb-6">
              <label for="mensaje" class="block text-sm font-semibold text-primary mb-2">
                Mensaje *
              </label>
              <textarea 
                id="mensaje" 
                name="mensaje"
                required
                rows="5"
                class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-secondary focus:border-transparent transition-all resize-none"
                placeholder="¿En qué podemos ayudarte?"
              ></textarea>
            </div>

            <div class="text-center">
              <button 
                type="submit"
                class="w-full md:w-auto px-8 py-4 bg-secondary text-white font-bold rounded-lg hover:opacity-90 transition-opacity"
              >
                Enviar Mensaje
              </button>
            </div>

            <p class="text-sm text-text-light text-center mt-4">
              Agradecemos tu comunicación, contactaremos contigo en el menor tiempo posible
            </p>
          </form>

          <!-- Success Message -->
          <div id="success-message" class="hidden bg-green-100 border border-green-400 text-green-700 px-6 py-4 rounded-lg mt-6 text-center">
            <p class="font-semibold">¡Mensaje enviado correctamente!</p>
            <p>Nos pondremos en contacto contigo pronto.</p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMessage = document.getElementById('success-message');

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const formData = new FormData(form);
      const data = Object.fromEntries(formData);
      
      // Log the data (in a real app, you'd send this to a backend)
      console.log('Form submitted:', data);
      
      // Simulate form submission
      form.style.display = 'none';
      if (successMessage) {
        successMessage.classList.remove('hidden');
      }
    });
  }
</script>
